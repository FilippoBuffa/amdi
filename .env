# ============================================================
#  AmdiApp — configurazione ambiente
#  Copia in .env e modifica i valori
# ============================================================

# PLC
ADS_USE_MOCK=false                # false per PLC reale
PLC_AMS_NET_ID=5.163.201.149.1.1
PLC_PORT=851
PLC_IP=192.168.0.11
PLC_LOCAL_AMS=                    # lascia vuoto = auto-detect (consigliato)
ADS_POLL_MS=50
ADS_HANDSHAKE_TIMEOUT=10.0
MOCK_PLC_READ_DELAY=1.5            # secondi prima che il mock "legga" i dati

# Telecamere
CAM_USE_REAL=true                  # true = BaslerCamera via IP; false = MockCamera
CAM_IP_TRACKING=10.10.90.10
CAM_IP_ANGLE=10.10.90.11
CAM_IP_INSPECTION=10.10.90.12
CAM_EXPOSURE_US=5000.0
CAM_GAIN_DB=0.0
MOCK_TRIGGER_INTERVAL=4.0          # usato solo se CAM_USE_REAL=false

# Vision
YOLO_MODEL_PATH=                   # lascia vuoto = stub
ANGLE_MODEL_PATH=
INSPECTION_MODEL_PATH=
PX_TO_CENTIMM=10.0
IMAGE_CENTER_X_PX=512
IMAGE_CENTER_Y_PX=512

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Log
LOG_LEVEL=INFO
