# ============================================================
#  AmdiApp — configurazione ambiente
#  Copia in .env e modifica i valori
# ============================================================

# PLC
ADS_USE_MOCK=false                # false per PLC reale
PLC_AMS_NET_ID=5.163.201.149.1.1
PLC_PORT=851
PLC_IP=192.168.0.11
PLC_LOCAL_AMS=                    # AMS Net ID del Jetson (es. 192.168.0.1.1.1)
ADS_POLL_MS=50
ADS_HANDSHAKE_TIMEOUT=10.0
MOCK_PLC_READ_DELAY=1.5            # secondi prima che il mock "legga" i dati

# Telecamere  (MOCK oppure serial number Basler)
CAM_SERIAL_TRACKING=MOCK
CAM_SERIAL_ANGLE=MOCK
CAM_SERIAL_INSPECTION=MOCK
MOCK_TRIGGER_INTERVAL=4.0          # secondi tra trigger automatici mock

# Vision
YOLO_MODEL_PATH=                   # lascia vuoto = stub
ANGLE_MODEL_PATH=
INSPECTION_MODEL_PATH=
PX_TO_CENTIMM=10.0
IMAGE_CENTER_X_PX=512
IMAGE_CENTER_Y_PX=512

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Log
LOG_LEVEL=INFO
